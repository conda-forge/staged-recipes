echo     [switch] $NoPathUpdate,
echo     [string] $PixiRepourl = 'https://github.com/prefix-dev/pixi'
echo )
echo.
echo Set-StrictMode -Version Latest
echo.
echo function Mask-Credentials {
echo     param(
echo         [string] $Url
echo     )
echo     return $Url -replace '://[^:@/]+:[^@/]+@', '://***:***@'
echo }
echo.
echo function Publish-Env {
