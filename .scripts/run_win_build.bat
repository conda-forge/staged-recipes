echo     Expand-Archive -Path $ZIP_FILE -DestinationPath $BinDir -Force
echo } catch {
echo     Write-Host "Error: '$(Mask-Credentials $DOWNLOAD_URL)' is not available or failed to download"
echo     exit 1
