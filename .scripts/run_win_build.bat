echo     $DOWNLOAD_URL = $Env:PIXI_DOWNLOAD_URL
echo } elseif ($PixiVersion -eq 'latest') {
echo     $DOWNLOAD_URL = "$PixiRepourl/releases/latest/download/$BINARY.zip"
echo } else {
