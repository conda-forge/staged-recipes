{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://schemas.conda.io/menuinst-1.schema.json",
  "menu_name": "croppy",
  "menu_items": [
    {
      "name": "croppy",
      "description": "Visual GUI for cropping, combining, and compressing videos via ffmpeg",
      "icon": "{{ MENU_DIR }}/croppy.{{ ICON_EXT }}",
      "command": ["{{ PREFIX }}/bin/croppy"],
      "activate": true,
      "terminal": false,
      "platforms": {
        "win": {
          "command": ["{{ SCRIPTS_DIR }}/croppy.exe"],
          "desktop": true,
          "app_user_model_id": "io.github.roaldarbol.croppy"
        },
        "linux": {
          "Categories": ["AudioVideo", "Video", "Qt"],
          "StartupWMClass": "croppy"
        },
        "osx": {
          "CFBundleName": "croppy",
          "CFBundleDisplayName": "croppy",
          "CFBundleIdentifier": "io.github.roaldarbol.croppy"
        }
      }
    }
  ]
}
