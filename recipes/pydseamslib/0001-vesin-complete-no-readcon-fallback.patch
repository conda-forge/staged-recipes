diff -ruN a/meson.build b/meson.build
--- a/meson.build	2026-04-06 20:59:58.000000000 -0500
+++ b/meson.build	2026-07-08 16:11:33.730711263 -0500
@@ -66,8 +66,7 @@
   _args += ['-DSEAMS_HAS_CHEMFILES=1']
 endif
 
-readcon_dep = dependency('readcon-core', required: false,
-                         fallback: ['readcon-core', 'readcon_dep'])
