diff -ruN a/subprojects/packagefiles/vesin/meson.build b/subprojects/packagefiles/vesin/meson.build
--- a/subprojects/packagefiles/vesin/meson.build	2026-04-06 20:59:58.000000000 -0500
+++ b/subprojects/packagefiles/vesin/meson.build	2026-07-08 16:11:33.730443879 -0500
@@ -5,20 +5,21 @@
 vesin_sources = files(
   'vesin/src/vesin.cpp',
   'vesin/src/cpu_cell_list.cpp',
+  'vesin/src/verlet.cpp',
   'vesin/src/shared_libraries.cpp',
   'vesin_cuda_stub.cpp',
 )
 
 vesin_inc = include_directories('vesin/include', 'vesin/src')
 
-# CPU cell-list only. GPU path requires vesin's CMake build with gpu-lite
