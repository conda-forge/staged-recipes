From 98fdb4867ac6b8d98045c87a0933c2814d6f3606 Mon Sep 17 00:00:00 2001
From: Tobias Fischer <info@tobiasfischer.info>
Date: Sun, 26 Apr 2026 10:12:30 +1000
Subject: [PATCH] meson: prefer conda-managed SDL dependencies

When building inside a conda environment, prefer the libraries under PREFIX so Meson finds the packaged SDL stack before system installations.

On Windows, use %PREFIX%\Library include/lib paths and skip pygame-ce's vendored prebuilt DLL bundle when a conda SDL stack is available. That avoids packaging older upstream SDL DLLs into site-packages/pygame, which can trigger runtime downgrade errors when pygame is compiled against newer conda-provided SDL libraries.

On non-Windows platforms, prepend PREFIX to the existing search bases so conda-provided SDL dependencies are discovered before system locations.
---
 meson.build | 63 +++++++++++++++++++++++++++++++++++++----------------
 1 file changed, 44 insertions(+), 19 deletions(-)

diff --git a/meson.build b/meson.build
index 783f3f9..0cb3583 100644
--- a/meson.build
+++ b/meson.build
@@ -87,6 +87,15 @@
 pg_inc_dirs = []
 pg_lib_dirs = []
 
+conda_prefix = run_command(
+    [
+        find_program('python3', 'python'),
+        '-c',
+        'import os; print(os.environ.get("PREFIX", ""))',
+    ],
+    check: true,
+).stdout().strip()
+
 if plat == 'emscripten-pygbag'
     sdl_dep = declare_dependency(
         link_args: ['-lSDL2'],
@@ -152,11 +161,22 @@
     prebuilt_dir = base_dir / 'pygame_win_deps_' + host_machine.cpu_family()
 
     dlls = []
+    conda_library_prefix = conda_prefix / 'Library'
+
+    if conda_prefix != '' and fs.is_dir(conda_library_prefix)
+        # In conda environments we should link against the packaged SDL stack
+        # rather than vendoring pygame-ce's upstream Windows prebuilts.
+        pg_inc_dirs += [
+            conda_library_prefix / 'include',
+            conda_library_prefix / 'include' / 'SDL2',
+            conda_library_prefix / 'include' / 'freetype2',
+        ]
+        pg_lib_dirs += conda_library_prefix / 'lib'
 
     # Here we first try the new prebuilts that CI makes available. If its not available
     # we fallback to legacy prebuilts if we are on intel/AMD, or do a system search for
     # the deps on other platforms.
-    if fs.is_dir(prebuilt_dir)
+    elif fs.is_dir(prebuilt_dir)
         lib_dir = prebuilt_dir / 'lib'
 
         # These are all the dlls that we need. There are no extra DLLs here.
@@ -329,26 +349,28 @@
         )
     endif
 
-    run_command(
-        [
-            find_program('python3', 'python'),
-            base_dir / 'buildconfig' / '_meson_win_dll.py',
-            dlls,
-        ],
-        check: true,
-    )
+    if dlls.length() > 0
+        run_command(
+            [
+                find_program('python3', 'python'),
+                base_dir / 'buildconfig' / '_meson_win_dll.py',
+                dlls,
+            ],
+            check: true,
+        )
 
-    foreach lib : dlls
-        if not fs.exists(lib)
-            error(f'''
-            File "@lib@" does not exist.
-            Please try to delete windows prebuilts and retry the installation.
-            ''')
-        endif
-    endforeach
+        foreach lib : dlls
+            if not fs.exists(lib)
+                error(f'''
+                File "@lib@" does not exist.
+                Please try to delete windows prebuilts and retry the installation.
+                ''')
+            endif
+        endforeach
 
-    # put dlls in root of install
-    install_data(dlls, install_dir: pg_dir, install_tag: 'pg-tag')
+        # put dlls in root of install
+        install_data(dlls, install_dir: pg_dir, install_tag: 'pg-tag')
+    endif
 
 else
     homebrew_prefix = '/opt/homebrew'
@@ -366,6 +388,9 @@
     endif
 
     bases = ['/usr/local', '/usr', homebrew_prefix, '/opt/local']
+    if conda_prefix != '' and fs.is_dir(conda_prefix)
+        bases = [conda_prefix] + bases
+    endif
     foreach inc_dir : bases
         foreach sub_inc : [
             '',
