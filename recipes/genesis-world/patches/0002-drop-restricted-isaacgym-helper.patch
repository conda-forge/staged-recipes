+def _get_isaacgym_terrain_utils():
+    try:
+        from genesis.ext.isaacgym import terrain_utils as isaacgym_terrain_utils
+    except ImportError as e:
+        gs.raise_exception_from(
+            "Procedural terrain generation is unavailable in this conda-forge build because the bundled "
+            "IsaacGym terrain helper cannot be redistributed. Pass a height_field explicitly instead.",
+            e,
+        )
+    return isaacgym_terrain_utils
+
+
