{
  "$schema": "https://schemas.conda.org/menuinst-1-1-3.schema.json",
  "menu_name": "Podman Desktop",
  "menu_items": [
    {
      "name": {
        "target_environment_is_base": "Podman Desktop",
        "target_environment_is_not_base": "Podman Desktop ({{ ENV_NAME }})"
      },
      "description": "Containers and Kubernetes for application developers",
      "command": [
        "{{ PREFIX }}/lib/podman-desktop/podman-desktop"
      ],
      "activate": true,
      "terminal": false,
      "platforms": {
        "linux": {
          "icon": "{{ MENU_DIR }}/podman-desktop.png",
          "Categories": ["Development"],
          "StartupNotify": true,
          "StartupWMClass": "Podman Desktop"
        },
        "osx": {
          "icon": "{{ MENU_DIR }}/podman-desktop.icns",
          "command": [
            "{{ PREFIX }}/lib/Podman Desktop.app/Contents/MacOS/Podman Desktop"
          ],
          "CFBundleIdentifier": "io.podman_desktop.PodmanDesktop",
          "CFBundleDisplayName": "Podman Desktop",
          "LSApplicationCategoryType": "public.app-category.developer-tools"
        },
        "win": {
          "command": [
            "{{ PREFIX }}/Library/lib/podman-desktop/Podman Desktop.exe"
          ],
          "desktop": false
        }
      }
    }
  ]
}
