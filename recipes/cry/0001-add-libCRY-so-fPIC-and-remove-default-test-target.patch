# Imported from basf2/externals/patches

--- Makefile
+++ Makefile
@@ -3,7 +3,7 @@
 #
 # Doug Wright

-default: setup lib test
+default: setup lib

 lib:
        $(MAKE) -C src
--- src/Makefile
+++ src/Makefile
@@ -6,10 +6,11 @@
 OBJ = $(SRC:%.cc=%.o)
 DEP = $(SRC:%.cc=.%.d)
 LIB = ../lib/libCRY.a
+ifeq ($(shell uname),Darwin)
+   SLIB = ../lib/libCRY.dylib
+   SHARED_FLAG = -dynamiclib
+else
+   SLIB = ../lib/libCRY.so
+   SHARED_FLAG = -shared
+endif

-CPPFLAGS += -Wall
+CPPFLAGS += -Wall -fPIC

-default: depend $(LIB)
+default: depend $(LIB) $(SLIB)

 depend: $(DEP)

@@ -23,8 +24,15 @@
        @ar -crs $(LIB) $(OBJ)
        @echo "Done making $(LIB)"

+$(SLIB): $(OBJ)
+       @if (test -f $(SLIB) ) then (rm $(SLIB)) fi
+       $(CXX) $(SHARED_FLAG) \
+       -o $(SLIB) \
+       $(OBJ)
+       @echo "Done making $(SLIB)"
+
 clean:
-       rm -f *.o .*.d ../lib/libCRY.a
+       rm -f *.o .*.d ../lib/libCRY.a $(SLIB)

 .PHONY: depend clean
