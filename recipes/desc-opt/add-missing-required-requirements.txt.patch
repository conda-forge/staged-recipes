From b1420e7b610e6df501e3b62753433ddc8b2f616e Mon Sep 17 00:00:00 2001
From: Matthew Feickert <matthew.feickert@cern.ch>
Date: Mon, 6 Apr 2026 18:15:43 -0600
Subject: [PATCH] fix: Add missing required requirements.txt

* setuptools is unable to build from an sdist without it.
---
 requirements.txt | 22 ++++++++++++++++++++++
 1 file changed, 22 insertions(+)
 create mode 100644 requirements.txt

diff --git a/requirements.txt b/requirements.txt
new file mode 100644
index 0000000..66f3d3d
--- /dev/null
+++ b/requirements.txt
@@ -0,0 +1,22 @@
+jax >= 0.5.0, != 0.5.1, != 0.5.2, != 0.6.0, != 0.7.1, < 0.10.0
+colorama <= 0.4.6
+diffrax >= 0.6.0, <= 0.7.2
+equinox >=0.11.10, <=0.13.6
+h5py >= 3.0.0, <= 3.16.0
+interpax >= 0.3.3, < 0.4
+jax-finufft >= 1.1.0, <= 1.3.0
+matplotlib >= 3.7.3, <= 3.10.8
+mpmath >= 1.0.0, <= 1.4.1
+netcdf4 >= 1.5.4, !=1.7.4, <= 1.7.5
+numpy >= 1.20.0, <= 2.4.3
+nvgpu <= 0.10.0
+optax <= 0.2.7
+orthax < 0.3
+plotly >= 5.16, <= 6.6.0
+psutil <= 7.2.2
+pylatexenc >= 2.0, <= 2.10
+quadax >= 0.2.2, < 0.3
+scikit-image <= 0.26.0
+scipy >= 1.7.0, <= 1.17.1
+sympy
+termcolor <= 3.3.0
