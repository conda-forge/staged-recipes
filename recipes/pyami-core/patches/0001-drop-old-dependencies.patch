diff --git a/pyAMI/app.py b/pyAMI/app.py
index 14877fe..2cbdb23 100644
--- a/pyAMI/app.py
+++ b/pyAMI/app.py
@@ -12,7 +12,7 @@ from __future__ import (division, print_function, unicode_literals)
 #
 #############################################################################
 
-import sys, argparse, argparseplus, pyAMI.modes, pyAMI.utils, pyAMI.client, pyAMI.config, pyAMI.exception
+import sys, argparse, pyAMI.modes, pyAMI.utils, pyAMI.client, pyAMI.config, pyAMI.exception
 
 #############################################################################
 
@@ -55,8 +55,6 @@ class App(object):
 
 		parser = argparse.ArgumentParser(epilog = pyAMI.config.bug_report)
 
-		argparseplus.patch(parser)
-
 		parser.add_argument('--authors', action = AuthorsAction)
 		parser.add_argument('--version', action = VersionAction)
 
diff --git a/pyAMI/transform.py b/pyAMI/transform.py
index be74de3..df1326b 100644
--- a/pyAMI/transform.py
+++ b/pyAMI/transform.py
@@ -13,40 +13,31 @@ from __future__ import (division, print_function, unicode_literals)
 #############################################################################
 
 import pyAMI.exception
-
+from lxml import etree
 #############################################################################
 
-def transform(xsl, xml):
-	#####################################################################
-	# IMPORT TINY_XSLT                                                  #
-	#####################################################################
-
-	try:
-		import tiny_xslt
-
-	except ImportError as e:
-		raise pyAMI.exception.Error('module `tiny_xslt` not properly installed: %s' % e)
-
-	#####################################################################
-	# OPEN CUSTOM XSL                                                   #
-	#####################################################################
-
-	try:
-		f = open(xsl, 'r')
-		xsl = f.read()
-		f.close()
-
-	except IOError:
-		raise pyAMI.exception.Error('could not open xslt file `%s`' % xsl)
-
-	#####################################################################
-	# APPLY XSL                                                         #
-	#####################################################################
-
-	try:
-		return tiny_xslt.transform(xsl, xml)
-
-	except tiny_xslt.Error as e:
-		raise pyAMI.exception.Error(e)
-
-#############################################################################
+def transform(xsl_path, xml):
+    #####################################################################
+    # OPEN CUSTOM XSL                                                   #
+    #####################################################################
+
+    try:
+        with open(xsl_path, 'r', encoding='utf-8') as f:
+            xsl_content = f.read()
+    except IOError:
+        raise pyAMI.exception.Error(f'could not open xslt file `{xsl_path}`')
+
+    #####################################################################
+    # APPLY XSL                                                         #
+    #####################################################################
+
+    try:
+        xml_doc = etree.fromstring(xml.encode('utf-8') if isinstance(xml, str) else xml)
+        xsl_doc = etree.fromstring(xsl_content.encode('utf-8'))
+        transformer = etree.XSLT(xsl_doc)
+        result = transformer(xml_doc)
+        return str(result)
+    except etree.XSLTApplyError as e:
+        raise pyAMI.exception.Error(f'XSLT transformation failed: {e}')
+    except etree.XMLSyntaxError as e:
+        raise pyAMI.exception.Error(f'Invalid XML or XSLT: {e}')
