 #
 #############################################################################
 
@@ -39,7 +40,7 @@ if __name__ == '__main__':
 		packages = ['pyAMI'],
 		package_data = {'': ['README', 'CHANGELOG', '*.txt'], 'pyAMI': ['*.txt']},
 		scripts = scripts,
-		install_requires = ['argparse', 'argparseplus', 'tiny_xslt'],
+		install_requires = [],
 		platforms = 'any',
 		zip_safe = False
 	)
