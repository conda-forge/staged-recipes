From: conda-forge <conda-forge@example.com>
Date: Mon, 07 Apr 2025 00:00:00 +0000
Subject: [PATCH] Use find_package for pybind11 and dlpack; alias nvcv_types_headers

The 3rdparty/ submodules are empty in the release tarball. Use conda-forge
packages for pybind11 and dlpack and locate them via find_package.

Also define nvcv_types_headers as an INTERFACE alias over the installed
nvcv_types target for the standalone Python build. In a full source build
this is created by src/nvcv/src/CMakeLists.txt; here we satisfy it via
the nvcv_types cmake config installed by libcvcuda-dev.
---
 python/CMakeLists.txt            | 9 +++++++++
 python/mod_cvcuda/CMakeLists.txt | 8 +-------
 2 files changed, 10 insertions(+), 8 deletions(-)

diff --git a/python/CMakeLists.txt b/python/CMakeLists.txt
index aaaaaaa..bbbbbbb 100644
--- a/python/CMakeLists.txt
+++ b/python/CMakeLists.txt
@@ -27,9 +27,17 @@ set(CMAKE_POSITION_INDEPENDENT_CODE true)

 set(PYBIND11_PYTHON_VERSION ${PYTHON_VERSION})
-add_subdirectory(${PYBIND11_SOURCE_DIR} pybind11)
+find_package(pybind11 REQUIRED)

 find_package(nvcv_types REQUIRED)

+# Alias nvcv_types_headers to the installed nvcv_types target for the standalone
+# Python build. In a full source build this is defined by src/nvcv/src/CMakeLists.txt;
+# here the installed nvcv_types already exports the same headers.
+if(NOT TARGET nvcv_types_headers)
+    add_library(nvcv_types_headers INTERFACE)
+    target_link_libraries(nvcv_types_headers INTERFACE nvcv_types)
+endif()
+
 add_subdirectory(${CMAKE_CURRENT_SOURCE_DIR}/../src/nvcv/util nvcv_util)
 add_subdirectory(${CMAKE_CURRENT_SOURCE_DIR}/../src/cvcuda/util cvcuda_util)

diff --git a/python/mod_cvcuda/CMakeLists.txt b/python/mod_cvcuda/CMakeLists.txt
index aaaaaaa..bbbbbbb 100644
--- a/python/mod_cvcuda/CMakeLists.txt
+++ b/python/mod_cvcuda/CMakeLists.txt
@@ -16,13 +16,7 @@ find_package(CUDAToolkit REQUIRED)
 find_package(cvcuda REQUIRED)
 find_package(CUDAToolkit REQUIRED)

-# Set up dlpack (needed for NVCV types)
-set(save_policy_0077 ${CMAKE_POLICY_DEFAULT_CMP0077})
-set(CMAKE_POLICY_DEFAULT_CMP0077 NEW)
-set(BUILD_MOCK OFF)
-set(BUILD_DOCS OFF)
-add_subdirectory(${DLPACK_SOURCE_DIR} dlpack)
-set(CMAKE_POLICY_DEFAULT_CMP0077 ${save_policy_0077})
+find_package(dlpack REQUIRED)

 # Generate NVCV type definitions
 set(imgformat_defs ${CMAKE_CURRENT_BINARY_DIR}/NVCVPythonImageFormatDefs.inc)
