+# Configurable Python module install directory (e.g. site-packages)
+set(FASTFRAMES_PYTHON_INSTALL_DIR "" CACHE PATH "Install Python modules to this directory")
+
+if(FASTFRAMES_PYTHON_INSTALL_DIR)
+  # Install Python entry point to bin/
+  install(PROGRAMS python/FastFrames.py DESTINATION bin)
+
+  # Install Python extension modules (.so) to site-packages
+  install(TARGETS ConfigReaderCpp cppLogger
+     LIBRARY DESTINATION "${FASTFRAMES_PYTHON_INSTALL_DIR}")
+
+  # Install Python packages
+  install(DIRECTORY python/ConfigReaderModules
