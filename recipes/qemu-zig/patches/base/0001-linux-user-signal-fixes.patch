From ed2077415cc808f362fee52f967d4d7526b0a49c Mon Sep 17 00:00:00 2001
From: Natanael Copa <ncopa@alpinelinux.org>
Date: Fri, 7 Nov 2025 00:32:04 +0100
Subject: [PATCH] linux-user/signal.c: define __SIGRTMIN/MAX for non-GNU
 platforms

The __SIGRTMIN and __SIGRTMAX are glibc internals and are not available
on all platforms, so we define those if they are missing.

This is needed for musl libc.

(cherry picked into Zig's QEMU fork by Alex Rønne Petersen)
---
 linux-user/signal.c | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/linux-user/signal.c b/linux-user/signal.c
index 804096bd44..45f0a0c5f2 100644
--- a/linux-user/signal.c
+++ b/linux-user/signal.c
@@ -42,6 +42,13 @@
 /* target_siginfo_t must fit in gdbstub's siginfo save area. */
 QEMU_BUILD_BUG_ON(sizeof(target_siginfo_t) > MAX_SIGINFO_LENGTH);

+#ifndef __SIGRTMIN
+#define __SIGRTMIN 32
+#endif
+#ifndef __SIGRTMAX
+#define __SIGRTMAX (NSIG-1)
+#endif
+
 static struct target_sigaction sigact_table[TARGET_NSIG];

 static void host_signal_handler(int host_signum, siginfo_t *info,
