From 0927f26b7faf817e6a9da60ae428b2e4065ea22a Mon Sep 17 00:00:00 2001
From: Érico Nogueira Rolim <erico.erc@gmail.com>
Date: Fri, 7 Nov 2025 00:38:35 +0100
Subject: [PATCH] linux-user/syscall.c: zero-initialize msg in
 do_sendrecvmsg_locked()

(cherry picked into Zig's QEMU fork by Alex Rønne Petersen)
---
 linux-user/syscall.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/linux-user/syscall.c b/linux-user/syscall.c
index 7404af9194..bcf012089f 100644
--- a/linux-user/syscall.c
+++ b/linux-user/syscall.c
@@ -3288,7 +3288,7 @@ static abi_long do_sendrecvmsg_locked(int fd, struct target_msghdr *msgp,
                                       int flags, int send)
 {
     abi_long ret, len;
-    struct msghdr msg;
+    struct msghdr msg = {0};
     abi_ulong count;
     struct iovec *vec;
     abi_ulong target_vec;
