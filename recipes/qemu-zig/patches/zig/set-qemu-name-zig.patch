# Rename QEMU linux-user binary to qemu-zig-{arch}
# This patch is analogous to set-qemu-name-execve.patch but for Zig variant
#
# TODO: This patch needs to be created by modifying the same files as
# set-qemu-name-execve.patch but using "qemu-zig-" as the prefix

--- qemu/configure
+++ qemu/configure
@@ -1656,3 +1656,3 @@
     *-linux-user|*-bsd-user)
-      qemu="qemu-$arch"
+      qemu="qemu-zig-$arch"
       ;;
--- qemu/linux-user/main.c
+++ qemu/linux-user/main.c
@@ -1656,3 +1656,3 @@
 {
-    printf("qemu-" TARGET_NAME " version " QEMU_FULL_VERSION
+    printf("qemu-zig-" TARGET_NAME " version " QEMU_FULL_VERSION
            "\n" QEMU_COPYRIGHT "\n");
--- qemu/meson.build
+++ qemu/meson.build
@@ -3998,3 +3998,3 @@
     execs = [{
-      'name': 'qemu-' + target_name,
+      'name': 'qemu-zig-' + target_name,
       'win_subsystem': 'console',
--- qemu/tests/functional/meson.build
+++ qemu/tests/functional/meson.build
@@ -3998,3 +3998,3 @@
       sysmode = 'linuxuser'
-      test_emulator = emulators['qemu-' + target_base]
+      test_emulator = emulators['qemu-zig-' + target_base]
     elif dir.endswith('-bsd-user')
