From: conda-forge <conda-forge@example.com>
Date: Sun, 06 Apr 2025 00:00:00 +0000
Subject: [PATCH] Use plain lib install directory instead of multiarch path

Debian/Ubuntu systems set CMAKE_LIBRARY_ARCHITECTURE (e.g. x86_64-linux-gnu),
causing libraries to be installed under lib/x86_64-linux-gnu. conda packages
expect libraries in lib/, so unconditionally set CMAKE_INSTALL_LIBDIR to lib.
---
 cmake/ConfigBuildTree.cmake | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/cmake/ConfigBuildTree.cmake b/cmake/ConfigBuildTree.cmake
index 1111111..2222222 100644
--- a/cmake/ConfigBuildTree.cmake
+++ b/cmake/ConfigBuildTree.cmake
@@ -24,7 +24,7 @@ set(CMAKE_LIBRARY_OUTPUT_DIRECTORY ${CMAKE_BINARY_DIR}/lib)

 include(GNUInstallDirs)

-set(CMAKE_INSTALL_LIBDIR "lib/${CMAKE_LIBRARY_ARCHITECTURE}")
+set(CMAKE_INSTALL_LIBDIR "lib")
 set(CMAKE_INSTALL_RPATH ${CMAKE_INSTALL_PREFIX}/${CMAKE_INSTALL_LIBDIR})

 # Executables try to find libnvvpi library relative to themselves.
