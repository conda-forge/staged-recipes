cmake_minimum_required(VERSION 3.7 FATAL_ERROR)
get_filename_component(HPTT_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
include(CMakeFindDependencyMacro)
find_dependency(OpenMP)
enable_language(C)
enable_language(CXX) 
if(NOT TARGET hptt::hptt)
  include("${HPTT_CMAKE_DIR}/hptt-targets.cmake")
endif()
