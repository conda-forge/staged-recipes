diff --git a/CMakeLists.txt b/CMakeLists.txt
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -31,3 +31,14 @@ if (NOT MSVC)
 endif ()
 
+if (DEFINED ENV{LIBRARY_PREFIX})
+    list(APPEND CMAKE_PREFIX_PATH "$ENV{LIBRARY_PREFIX}")
+    set(CMAKE_FIND_PACKAGE_PREFER_CONFIG ON)
+    # SUNDIALS 7.x Config sets only imported targets, not SUNDIALS_LIBRARIES.
+    # Ignore it so cmake falls back to FindSUNDIALS.cmake which sets SUNDIALS_LIBRARIES.
+    list(APPEND CMAKE_IGNORE_PATH "$ENV{LIBRARY_PREFIX}/lib/cmake/sundials")
+    # Pre-find BLAS so FindSuiteSparse.cmake BLAS_FOUND check passes.
+    # (Previously a side-effect of SUNDIALS CONFIG mode; now made explicit.)
+    find_package(BLAS QUIET)
+endif ()
+
 find_package(pybind11 CONFIG REQUIRED)
