From: jdegenstein <jdegenstein@users.noreply.github.com>
Date: Wed, 8 Jul 2026 16:10:00 -0500
Subject: [PATCH] Remove PyPI OCP dependency

- conda-forge provides 'ocp', so we strip the PyPI-specific proxy requirement 
- to prevent pip check failures during the conda build.
---
 pyproject.toml | 1 -
 1 file changed, 1 deletion(-)

diff --git a/pyproject.toml b/pyproject.toml
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -13,7 +13,6 @@
     "Topic :: Software Development :: Libraries :: Python Modules",
 ]
 dependencies = [
-    "cadquery_ocp_proxy >= 7.9, < 8.0",
     "numpy >= 2, < 3",
     "scipy",
 ]
