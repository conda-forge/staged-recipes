From: Matthew Feickert <matthew.feickert@cern.ch>
Date: Tue, 27 May 2025 21:59:44 -0600
Subject: [PATCH] build: Remove pytest from runtime dependencies

* pytest is never used in the quantem library and should not be required for
  install.
---
 pyproject.toml | 1 -
 1 file changed, 1 deletion(-)

diff --git a/pyproject.toml b/pyproject.toml
index eddfed4..c36d798 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -38,7 +38,6 @@ dependencies = [
   "cmasher>=1.9.2",
   "rosettasciio>=0.8.0",
   "h5py>=3.13.0",
-  "pytest>=8.3.5",
 ]
 
 [dependency-groups]
