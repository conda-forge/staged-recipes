       triple.str(), CUDAContext::get_instance().get_mcpu(), cuda_mattrs(),
       options, llvm::Reloc::PIC_, llvm::CodeModel::Small,
+#if LLVM_VERSION_MAJOR >= 18
+      CodeGenOptLevel::Aggressive));
+#else
       CodeGenOpt::Aggressive));
