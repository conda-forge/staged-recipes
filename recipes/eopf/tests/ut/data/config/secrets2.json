{
    "secret_bindings": {
        "s3://cpm-input": "cpm-input"
    },
    "cpm-input": {
        "key": "key2",
        "secret": "${SECRET_PASS2}",
        "client_kwargs": {
            "endpoint_url": "<URL>",
            "region_name": "<REGION>"
        },
        "s3_additional_kwargs": {
            "StorageClass": "EXPRESS_ONEZONE"
        }
    }
}
