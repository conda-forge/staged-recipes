--- a/cpp/cc/freeres/freeres.cc
+++ b/cpp/cc/freeres/freeres.cc
@@ -10,12 +10,13 @@
 // use it during library tear-down may cause a segmentation fault.
 // The emergency pool is only used if an exception was thrown *and* `malloc` failed in an OOM system, so
 // this is a calculated risk we are willing to live with.
-namespace __gnu_cxx
-{
-    __attribute__((visibility("hidden"))) void __freeres();
-} // namespace __gnu_cxx
-
+// __gnu_cxx::__freeres() is a hidden symbol that only exists in the *static*
+// libstdc++ archive (libstdc++.a). The upstream devcontainer links libstdc++
+// statically (-static-libstdc++ -l:libstdc++.a, see toolchain/template/toolchain.bzl),
+// so the symbol is available there. The conda-forge build links libstdc++
+// dynamically, where the symbol is not exported; the emergency-pool cleanup is
+// only relevant for shared libraries that are *statically* linked against
+// libstdc++ and repeatedly loaded/unloaded, so it is a no-op here.
 __attribute__((destructor)) void __free_pool()
 {
-    __gnu_cxx::__freeres();
 }
