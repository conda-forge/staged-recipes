From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: conda-forge staged-recipes <conda-forge@users.noreply.github.com>
Date: Sun, 10 May 2026 13:05:00 -0700
Subject: [PATCH] Limit wheel install manifest to Python package artifacts

---
 setup.py | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/setup.py b/setup.py
index 955d745..c6ec2ad 100644
--- a/setup.py
+++ b/setup.py
@@ -55,6 +55,9 @@ def copy_assets():
     remove_tmp(quadrants_dir)
 
     shutil.copytree("external/assets", os.path.join(quadrants_dir, "assets"))
+    asset_git_marker = os.path.join(quadrants_dir, "assets", ".git")
+    if os.path.exists(asset_git_marker):
+        os.remove(asset_git_marker)
 
 
 class Clean(clean):
@@ -194,6 +197,10 @@ WHITELISTED_FILES = [
 def cmake_install_manifest_filter(manifest_files):
     def should_include(f):
         basename = os.path.basename(f)
+        normalized = f.replace(os.sep, "/")
+        if "/python/quadrants/" not in normalized:
+            return False
+
         if basename in WHITELISTED_FILES:
             return True
         if basename in BLACKLISTED_FILES:
