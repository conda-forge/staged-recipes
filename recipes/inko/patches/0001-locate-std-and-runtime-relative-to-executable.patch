+/// Resolves a directory that ships alongside the compiler binary.
+///
+/// Precedence:
+///   1. The environment variable `env_var`, if set.
+///   2. `<exe_dir>/../<relative>` if it is an existing directory. This
+///      lets an installed `bin/inko` discover its sibling `lib/inko/...`
+///      directory without any compile-time path baked in, which is what
+///      relocatable package managers (conda, pixi, nix) require.
+///   3. The compile-time `fallback` value, used by `cargo run` from a
+///      source checkout.
+fn locate_sibling(
+    env_var: &str,
+    relative: &[&str],
+    fallback: &str,
+) -> PathBuf {
+    if let Some(value) = env::var_os(env_var) {
+        return PathBuf::from(value);
+    }
+
+    if let Ok(exe) = env::current_exe() {
+        if let Some(bin_dir) = exe.parent() {
+            if let Some(prefix) = bin_dir.parent() {
+                let mut candidate = prefix.to_path_buf();
+                for part in relative {
+                    candidate.push(part);
+                }
+                if candidate.is_dir() {
+                    return candidate;
+                }
+            }
+        }
+    }
+
+    PathBuf::from(fallback)
+}
