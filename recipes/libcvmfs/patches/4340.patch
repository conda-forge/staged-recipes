From 89e82f1b244d34d08f90b92bfd0419a9305c8959 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Sat, 18 Jul 2026 15:29:58 +0200
Subject: [PATCH 1/3] fix: only default to the CLT SDK on macOS when the env
 does not set one

The hardcoded -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk
and -mmacosx-version-min=10.14 flags override any SDK or deployment target
selected by the build environment, which breaks builds with toolchains that
provide their own SDK (e.g. conda-forge, Homebrew clang, CI images with
pinned SDKs). Keep the current behaviour as a fallback but skip it when
SDKROOT or MACOSX_DEPLOYMENT_TARGET is set, both of which clang reads
natively.
---
 cmake/Modules/cvmfs_compiler.cmake | 10 ++++++++--
 1 file changed, 8 insertions(+), 2 deletions(-)

diff --git a/cmake/Modules/cvmfs_compiler.cmake b/cmake/Modules/cvmfs_compiler.cmake
index be4544aae7..2f254e768a 100644
--- a/cmake/Modules/cvmfs_compiler.cmake
+++ b/cmake/Modules/cvmfs_compiler.cmake
@@ -63,8 +63,14 @@ endif (CMAKE_COMPILER_IS_GNUCC)
 message (STATUS "using compiler opt flag ${CVMFS_OPT_FLAGS}")
 set (CVMFS_BASE_C_FLAGS "${CVMFS_OPT_FLAGS} -g -fno-strict-aliasing -fasynchronous-unwind-tables -fno-omit-frame-pointer -fwrapv -fvisibility=hidden -Wall ${CVMFS_FIX_FLAGS}")
 if (APPLE)
-  set(MACOSX_DEPLOYMENT_TARGET "10.14")
-  set(CVMFS_BASE_C_FLAGS "${CVMFS_BASE_C_FLAGS} -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -mmacosx-version-min=10.14")
+  # Fall back to the Command Line Tools SDK and a default deployment target
+  # unless the build environment already selects them (through the SDKROOT
+  # and MACOSX_DEPLOYMENT_TARGET environment variables, which clang honors),
+  # so that non-default toolchains can use their own SDK.
+  if ("$ENV{SDKROOT}" STREQUAL "" AND "$ENV{MACOSX_DEPLOYMENT_TARGET}" STREQUAL "")
+    set(MACOSX_DEPLOYMENT_TARGET "10.14")
+    set(CVMFS_BASE_C_FLAGS "${CVMFS_BASE_C_FLAGS} -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -mmacosx-version-min=10.14")
+  endif()
 endif(APPLE)
 set (CVMFS_BASE_CXX_FLAGS "${CVMFS_BASE_C_FLAGS} -fno-exceptions")
 if (NOT USING_CLANG)

From ee10a84360fc8cfe2ac2117e2b8c6eca985001d8 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Sun, 19 Jul 2026 00:04:43 +0200
Subject: [PATCH 2/3] fix: use the configured compiler for the sha3
 architecture probe

The probe used the unprefixed cc, which does not exist in minimal build
environments. Use $CC when set. Cross builds can still pre-create the
arch file to skip running the probe binaries.
---
 externals/sha3/src/makeHook.sh | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/externals/sha3/src/makeHook.sh b/externals/sha3/src/makeHook.sh
index 7743eb57e8..ce71e46e73 100755
--- a/externals/sha3/src/makeHook.sh
+++ b/externals/sha3/src/makeHook.sh
@@ -2,7 +2,7 @@
 
 if [ ! -f arch ]; then
   echo '#include <stdio.h>
-    int main(){printf("%d", sizeof(long));return 0;}' | cc -x c -
+    int main(){printf("%d", sizeof(long));return 0;}' | ${CC:-cc} -x c -
   SIZEOF_LONG=$(./a.out)
   rm -f a.out
   case $SIZEOF_LONG in
@@ -11,7 +11,7 @@ if [ ! -f arch ]; then
 #ifdef __x86_64__
 return 0;
 #endif
-return 1;}' | cc -x c -
+return 1;}' | ${CC:-cc} -x c -
       ./a.out
       x86_64=$?
       rm -f a.out

From 0489cd7cfa35f13c5d51ad9362d7a05439c9ce00 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Sat, 18 Jul 2026 23:27:34 +0200
Subject: [PATCH 3/3] fix: find the built-in externals under cross-compiling
 toolchains

Toolchains that set CMAKE_FIND_ROOT_PATH_MODE_LIBRARY=ONLY re-root every
find_library/find_path call, which hides the externals install tree from
the Libcrypto and SHA3 modules because it lives in the source directory.
The built-in externals are always at a known absolute location, so exempt
these lookups from re-rooting and give the SHA3 module the externals
install location as an explicit hint.
---
 cmake/Modules/FindLibcrypto.cmake | 2 ++
 cmake/Modules/FindSHA3.cmake      | 6 ++++--
 2 files changed, 6 insertions(+), 2 deletions(-)

diff --git a/cmake/Modules/FindLibcrypto.cmake b/cmake/Modules/FindLibcrypto.cmake
index 8af068571a..a563f03577 100644
--- a/cmake/Modules/FindLibcrypto.cmake
+++ b/cmake/Modules/FindLibcrypto.cmake
@@ -12,6 +12,7 @@ find_path(
     NAMES tls.h
     PATHS ${EXTERNALS_INSTALL_LOCATION}/crypto/include
     NO_DEFAULT_PATH
+    NO_CMAKE_FIND_ROOT_PATH
 )
 
 find_library(
@@ -19,6 +20,7 @@ find_library(
     NAMES crypto
     PATHS ${EXTERNALS_INSTALL_LOCATION}/crypto/lib
     NO_DEFAULT_PATH
+    NO_CMAKE_FIND_ROOT_PATH
 )
 
 include(FindPackageHandleStandardArgs)
diff --git a/cmake/Modules/FindSHA3.cmake b/cmake/Modules/FindSHA3.cmake
index cb72a65fbe..8bcf179e31 100644
--- a/cmake/Modules/FindSHA3.cmake
+++ b/cmake/Modules/FindSHA3.cmake
@@ -10,13 +10,15 @@
 find_path(
     SHA3_INCLUDE_DIRS
     NAMES SnP-interface.h
-    HINTS ${SHA3_INCLUDE_DIRS}
+    HINTS ${SHA3_INCLUDE_DIRS} ${EXTERNALS_INSTALL_LOCATION}/include
+    NO_CMAKE_FIND_ROOT_PATH
 )
 
 find_library(
     SHA3_LIBRARIES
     NAMES sha3
-    HINTS ${SHA3_LIBRARY_DIRS}
+    HINTS ${SHA3_LIBRARY_DIRS} ${EXTERNALS_INSTALL_LOCATION}/lib
+    NO_CMAKE_FIND_ROOT_PATH
 )
 
 include(FindPackageHandleStandardArgs)
