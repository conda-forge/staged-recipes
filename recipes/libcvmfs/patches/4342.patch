From d9aadc343f22d5996be1955dbe2af949258d2042 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Sun, 19 Jul 2026 00:22:23 +0200
Subject: [PATCH] fix: respect an explicitly configured CMAKE_INSTALL_LIBDIR

The library directory defaults were plain set() calls, so an explicit
-DCMAKE_INSTALL_LIBDIR on the command line was silently overridden (for
example, lib64 was always used on RedHat-flavoured 64-bit systems).
Declare the defaults as non-forced cache variables so a user-provided
value takes precedence while the platform defaults stay unchanged.
---
 CMakeLists.txt | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 513c4e8508..2ca24c8044 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -150,7 +150,7 @@ endif ()
 #       (https://wiki.debian.org/Multiarch)
 #
 if (MACOSX)
-  set (CMAKE_INSTALL_LIBDIR "lib")
+  set (CMAKE_INSTALL_LIBDIR "lib" CACHE STRING "library installation directory")
   set (CMAKE_MOUNT_INSTALL_BINDIR "${CMAKE_INSTALL_PREFIX}/sbin")
   set (CVMFS_LIBEXEC_DIR "libexec/cvmfs")
   set (CMAKE_MACOSX_RPATH true)
@@ -164,14 +164,14 @@ else (MACOSX) # --> Linux
       set (CMAKE_MOUNT_INSTALL_BINDIR "/sbin")
       set (CVMFS_LIBEXEC_DIR "libexec/cvmfs")
     endif (ARCHLINUX)
-    set (CMAKE_INSTALL_LIBDIR "lib")
+    set (CMAKE_INSTALL_LIBDIR "lib" CACHE STRING "library installation directory")
   else (DEBIAN OR ARCHLINUX) # --> RedHat, Fedora, CentOS, SuSE
     set (CMAKE_MOUNT_INSTALL_BINDIR "/sbin")
     set (CVMFS_LIBEXEC_DIR "libexec/cvmfs")
     if (IS_64_BIT)
-      set (CMAKE_INSTALL_LIBDIR "lib64")
+      set (CMAKE_INSTALL_LIBDIR "lib64" CACHE STRING "library installation directory")
     else (IS_64_BIT) # --> 32 Bit
-      set (CMAKE_INSTALL_LIBDIR "lib")
+      set (CMAKE_INSTALL_LIBDIR "lib" CACHE STRING "library installation directory")
     endif (IS_64_BIT)
   endif (DEBIAN OR ARCHLINUX)
 endif (MACOSX)
