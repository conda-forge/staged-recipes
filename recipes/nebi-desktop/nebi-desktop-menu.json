{
    "$schema": "https://schemas.conda.org/menuinst/menuinst-1-1-0.schema.json",
    "menu_name": "Nebi Desktop",
    "menu_items": [
        {
            "name": "Nebi Desktop",
            "description": "Local-first workspace management for Pixi",
            "icon": "{{ MENU_DIR }}/nebi.{{ ICON_EXT }}",
            "command": ["{{ BIN_DIR }}/nebi-desktop"],
            "terminal": false,
            "platforms": {
                "linux": {
                    "Categories": ["Development", "Utility"]
                },
                "osx": {
                    "CFBundleName": "Nebi",
                    "CFBundleIdentifier": "com.openteams.nebi-desktop",
                    "CFBundleVersion": "__PKG_VERSION__"
                },
                "win": {
                    "desktop": true
                }
            }
        }
    ]
}
