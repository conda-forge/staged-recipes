From 321a27f64dba7c883526f1aae5a1367ef7b19955 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Sat, 17 Jan 2026 23:53:24 +0100
Subject: [PATCH 4/9] fix: Output pthread_t as decimal for macOS compatibility

pthread_t is an unsigned long on Linux but a pointer on macOS,
causing it to print in hex format (0x...) which broke the timeline
test's regex that expects decimal digits.
---
 GaudiHive/src/TimelineSvc.cpp | 15 +++++++++++----
 1 file changed, 11 insertions(+), 4 deletions(-)

diff --git a/GaudiHive/src/TimelineSvc.cpp b/GaudiHive/src/TimelineSvc.cpp
index 23f1f6f6d..2c247d3c5 100644
--- a/GaudiHive/src/TimelineSvc.cpp
+++ b/GaudiHive/src/TimelineSvc.cpp
@@ -1,5 +1,5 @@
 /***********************************************************************************\
-* (c) Copyright 1998-2025 CERN for the benefit of the LHCb and ATLAS collaborations *
+* (c) Copyright 1998-2026 CERN for the benefit of the LHCb and ATLAS collaborations *
 *                                                                                   *
 * This software is distributed under the terms of the Apache version 2 licence,     *
 * copied verbatim in the file "LICENSE".                                            *
@@ -13,8 +13,15 @@
 #include <GaudiKernel/StatusCode.h>
 #include <GaudiKernel/TimelineEvent.h>
 
+#include <cstdint>
 #include <fstream>
 
+namespace {
+  // pthread_t is an unsigned long on Linux but a pointer on macOS.
+  // Cast to uintptr_t for consistent decimal output across platforms.
+  std::uintptr_t thread_to_int( pthread_t t ) { return reinterpret_cast<std::uintptr_t>( t ); }
+} // namespace
+
 StatusCode TimelineSvc::initialize() {
   StatusCode sc = Service::initialize();
   if ( !sc.isSuccess() ) return sc;
@@ -66,8 +73,8 @@ ITimelineSvc::TimelineRecorder TimelineSvc::getRecorder( std::string alg, const
     out << std::chrono::duration_cast<std::chrono::nanoseconds>( newTimelineEvent.start.time_since_epoch() ).count()
         << " "
         << std::chrono::duration_cast<std::chrono::nanoseconds>( newTimelineEvent.end.time_since_epoch() ).count()
-        << " " << newTimelineEvent.algorithm << " " << newTimelineEvent.thread << " " << newTimelineEvent.slot << " "
-        << newTimelineEvent.event << std::endl;
+        << " " << newTimelineEvent.algorithm << " " << thread_to_int( newTimelineEvent.thread ) << " "
+        << newTimelineEvent.slot << " " << newTimelineEvent.event << std::endl;
 
     out.close();
   }
@@ -92,7 +99,7 @@ void TimelineSvc::outputTimeline() {
   for ( const auto& e : m_events ) {
     out << std::chrono::duration_cast<std::chrono::nanoseconds>( e.start.time_since_epoch() ).count() << " "
         << std::chrono::duration_cast<std::chrono::nanoseconds>( e.end.time_since_epoch() ).count() << " "
-        << e.algorithm << " " << e.thread << " " << e.slot << " " << e.event << std::endl;
+        << e.algorithm << " " << thread_to_int( e.thread ) << " " << e.slot << " " << e.event << std::endl;
   }
 
   out.close();
-- 
