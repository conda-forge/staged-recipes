From a2a2b6a4b7441520fe234d28082b72c4beaa0764 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Tue, 9 Jun 2026 10:40:22 +0200
Subject: [PATCH] fix: scan default plugin path in Registry::initialize

!1925 added getDefaultPluginPath() and used it in loadPluginLibrary(),
but Registry::initialize() still only scanned GAUDI_PLUGIN_PATH and
LD_LIBRARY_PATH (or DYLD_LIBRARY_PATH on macOS) when looking for
.components files. In a Conda/pixi environment where the plugin
directory is not on (DY)LD_LIBRARY_PATH and GAUDI_PLUGIN_PATH is unset,
the factory registry ends up empty and any factory lookup fails before
loadPluginLibrary() is ever called.

Mirror the loadPluginLibrary() fix and prepend the default plugin path
to the search list in Registry::initialize() as well, so .components
files in the directory next to libGaudiPluginService are discovered
without any environment variable being set.
---
 GaudiPluginService/src/PluginServiceV2.cpp | 9 ++++++++-
 1 file changed, 8 insertions(+), 1 deletion(-)

diff --git a/GaudiPluginService/src/PluginServiceV2.cpp b/GaudiPluginService/src/PluginServiceV2.cpp
index bc75889..439f38d 100644
--- a/GaudiPluginService/src/PluginServiceV2.cpp
+++ b/GaudiPluginService/src/PluginServiceV2.cpp
@@ -147,11 +147,18 @@ namespace Gaudi {
           const char sep     = ':';
 #endif
 
+          const std::string defaultPluginPath = getDefaultPluginPath();
+
           std::regex line_format{ "^(?:[[:space:]]*(?:(v[0-9]+)::)?([^:]+):(.*[^[:space:]]))?[[:space:]]*(?:#.*)?$" };
           for ( const auto& envVar : envVars ) {
             std::smatch       m;
             std::stringstream search_path;
-            if ( auto ptr = std::getenv( envVar ) ) search_path << ptr;
+            if ( !defaultPluginPath.empty() ) {
+              search_path << defaultPluginPath;
+              if ( auto ptr = std::getenv( envVar ) ) search_path << sep << ptr;
+            } else {
+              if ( auto ptr = std::getenv( envVar ) ) search_path << ptr;
+            }
             logger().debug( std::string( "searching factories in " ) + envVar );
 
             // std::string_view::size_type start_pos = 0, end_pos = 0;
