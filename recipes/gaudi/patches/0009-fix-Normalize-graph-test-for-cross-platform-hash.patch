+import re
+
 from GaudiTesting import GaudiExeTest
 
 
+def normalize_graph(graph):
+    """Normalize obj_* IDs and line order for platform-independent comparison.
+
+    std::hash<std::string> produces different values on different platforms
+    (libstdc++ vs libc++), so we normalize obj_HASH to obj_N based on the
+    label they're associated with. We also sort the body lines since the
+    output order may vary.
+    """
+    # Extract mapping from obj_* IDs to their labels
+    label_pattern = re.compile(r"(obj_\d+) \[label=\"([^\"]+)\"")
+    id_to_label = {}
+    for match in label_pattern.finditer(graph):
+        id_to_label[match.group(1)] = match.group(2)
+
+    # Create normalized IDs based on sorted labels for deterministic ordering
+    sorted_labels = sorted(id_to_label.items(), key=lambda x: x[1])
+    id_mapping = {old_id: f"obj_{i}" for i, (old_id, _) in enumerate(sorted_labels)}
+
+    # Replace all obj_* IDs with normalized versions
+    result = graph
+    for old_id, new_id in id_mapping.items():
+        result = result.replace(old_id, new_id)
+
+    # Sort the body lines (between header and closing brace) for order-independence
+    lines = result.strip().split("\n")
+    header = lines[:2]  # "digraph datadeps {" and "rankdir=..."
+    footer = lines[-1:]  # "}"
+    body = sorted(lines[2:-1])
+    return "\n".join(header + body + footer)
+
+
 class Test(GaudiExeTest):
     command = ["gaudirun.py", "-v", "../../../options/AvalancheSchedulerSimpleTest.py"]
     timeout = 120
 
     def test_graph_file(self, cwd):
+        # Reference graph with normalized obj_* IDs (sorted by label)
+        # obj_0 = /Event/a1, obj_1 = /Event/a2, obj_2 = /Event/a3, obj_3 = /Event/a4
         ref = """digraph datadeps {
   rankdir="LR";
   Alg_0 [label="A1";shape=box];
-  obj_13600394293829281201 [label="/Event/a1";shape=box];
-  Alg_0 -> obj_13600394293829281201;
+  obj_0 [label="/Event/a1";shape=box];
+  Alg_0 -> obj_0;
   Alg_1 [label="A2";shape=box];
-  obj_13600394293829281201 -> Alg_1;
-  obj_1573251618719251457 [label="/Event/a2";shape=box];
-  Alg_1 -> obj_1573251618719251457;
+  obj_0 -> Alg_1;
+  obj_1 [label="/Event/a2";shape=box];
+  Alg_1 -> obj_1;
   Alg_2 [label="A3";shape=box];
-  obj_13600394293829281201 -> Alg_2;
-  obj_15861236635915656172 [label="/Event/a3";shape=box];
-  Alg_2 -> obj_15861236635915656172;
+  obj_0 -> Alg_2;
+  obj_2 [label="/Event/a3";shape=box];
+  Alg_2 -> obj_2;
   Alg_3 [label="A4";shape=box];
-  obj_15861236635915656172 -> Alg_3;
-  obj_1573251618719251457 -> Alg_3;
-  obj_9576344950949101152 [label="/Event/a4";shape=box];
-  Alg_3 -> obj_9576344950949101152;
+  obj_2 -> Alg_3;
+  obj_1 -> Alg_3;
   Alg_4 [label="CNT&";shape=box];
   Alg_5 [label="CNT*";shape=box];
+  obj_3 [label="/Event/a4";shape=box];
+  Alg_3 -> obj_3;
 }
 """
         graph = open(f"{cwd}/graphDump.dot").read()
-        assert graph == ref
+        assert normalize_graph(graph) == normalize_graph(ref)
