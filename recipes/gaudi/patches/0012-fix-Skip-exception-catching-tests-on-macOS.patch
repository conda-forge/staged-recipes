From 1b066a75e6a6ecd5e5743314c0ca363a3c829eea Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Sat, 17 Jan 2026 23:40:23 +0100
Subject: [PATCH 9/9] fix: Skip exception-catching tests on macOS due to cppyy
 limitation

C++ exceptions thrown through cppyy don't propagate to Python properly
on macOS and instead terminate the process.
See https://github.com/root-project/root/issues/7541
---
 GaudiTestSuite/scripts/ExtendedProperties2.py | 24 +++++++++++--------
 1 file changed, 14 insertions(+), 10 deletions(-)

diff --git a/GaudiTestSuite/scripts/ExtendedProperties2.py b/GaudiTestSuite/scripts/ExtendedProperties2.py
index fe47b8065..28b36bce4 100755
--- a/GaudiTestSuite/scripts/ExtendedProperties2.py
+++ b/GaudiTestSuite/scripts/ExtendedProperties2.py
@@ -1,6 +1,6 @@
 #!/usr/bin/env python3
 #####################################################################################
-# (c) Copyright 1998-2023 CERN for the benefit of the LHCb and ATLAS collaborations #
+# (c) Copyright 1998-2026 CERN for the benefit of the LHCb and ATLAS collaborations #
 #                                                                                   #
 # This software is distributed under the terms of the Apache version 2 licence,     #
 # copied verbatim in the file "LICENSE".                                            #
@@ -35,6 +35,9 @@ from Configurables import Gaudi__TestSuite__ExtendedProperties2 as EP2
 # =============================================================================
 
 isWin = sys.platform.startswith("win")
+# On macOS, C++ exceptions thrown through cppyy don't propagate to Python properly
+# and instead terminate the process. See https://github.com/root-project/root/issues/7541
+isMac = sys.platform == "darwin"
 
 ep2 = EP2("xProps2", Point3D=(10, 40, 55), Points3D=[(10, 40, 55), (1, 2, 3)])
 
@@ -78,17 +81,18 @@ if "__main__" == __name__:
 
     xp2.SVector5 = [1, 2, 3, 4, 5]
 
-    try:
-        xp2.SVector5 = [1, 2, 3, 4, 5, 6]
-    except Exception as e:
-        print(" Exception: ", e)
+    if not isMac:
+        try:
+            xp2.SVector5 = [1, 2, 3, 4, 5, 6]
+        except Exception as e:
+            print(" Exception: ", e)
 
-    try:
-        xp2.Point3D = (1, 2, 3, 4)
-    except Exception as e:
-        print(" Exception: ", e)
+        try:
+            xp2.Point3D = (1, 2, 3, 4)
+        except Exception as e:
+            print(" Exception: ", e)
 
-    if not isWin:
+    if not isWin and not isMac:
         try:
             xp2.Vector4D = (1, 2, 3)
         except Exception as e:
-- 
