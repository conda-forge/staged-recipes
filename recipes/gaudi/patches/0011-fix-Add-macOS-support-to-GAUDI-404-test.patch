From 2079816a43f0957511b96a74a10fa9cfda6d1710 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Sun, 18 Jan 2026 00:23:44 +0100
Subject: [PATCH 8/9] fix: Add macOS support to GAUDI-404 test

Use platform-appropriate library extension (.dylib vs .so), library
search path (GAUDI_PLUGIN_PATH), and symbol demangling (c++filt vs
nm -C) to enable this test on macOS.
---
 .../tests/pytest/jira/test_gaudi_404.py       | 37 +++++++++++++------
 1 file changed, 25 insertions(+), 12 deletions(-)

diff --git a/GaudiKernel/tests/pytest/jira/test_gaudi_404.py b/GaudiKernel/tests/pytest/jira/test_gaudi_404.py
index dc700bcb4..6b5b9da0f 100644
--- a/GaudiKernel/tests/pytest/jira/test_gaudi_404.py
+++ b/GaudiKernel/tests/pytest/jira/test_gaudi_404.py
@@ -1,6 +1,6 @@
 #!/usr/bin/env python3
 #####################################################################################
-# (c) Copyright 1998-2024 CERN for the benefit of the LHCb and ATLAS collaborations #
+# (c) Copyright 1998-2026 CERN for the benefit of the LHCb and ATLAS collaborations #
 #                                                                                   #
 # This software is distributed under the terms of the Apache version 2 licence,     #
 # copied verbatim in the file "LICENSE".                                            #
@@ -11,6 +11,7 @@
 #####################################################################################
 import os
 import re
+import sys
 from subprocess import PIPE, run
 
 import pytest
@@ -18,7 +19,7 @@ from GaudiTesting import platform_matches
 
 
 @pytest.mark.skipif(
-    platform_matches(["win", "mac"]),
+    platform_matches(["win"]),
     reason="Unsupported platform",
 )
 def test():
@@ -27,26 +28,38 @@ def test():
     GaudiKernel.
     See https://its.cern.ch/jira/browse/GAUDI-404
     """
-    # find libGaudiKernel.so in the LD_LIBRARY_PATH
-    libname = "libGaudiKernel.so"
+    # find libGaudiKernel in the library path
+    libext = {"darwin": ".dylib"}.get(sys.platform, ".so")
+    libname = f"libGaudiKernel{libext}"
 
     searchpath = [os.path.curdir, "lib"]
-    # The day we can run the test on other platforms we can do this:
-    # varname = {'darwin': 'DYLD_LIBRARY_PATH',
-    #           'win32': 'PATH'}.get(sys.platform, 'LD_LIBRARY_PATH')
-    varname = "LD_LIBRARY_PATH"
-    searchpath.extend(os.environ.get(varname, "").split(os.pathsep))
+    # On macOS: use GAUDI_PLUGIN_PATH only (LD_LIBRARY_PATH is ignored by SIP)
+    # On Linux: use GAUDI_PLUGIN_PATH and LD_LIBRARY_PATH
+    varnames = ["GAUDI_PLUGIN_PATH"]
+    if sys.platform != "darwin":
+        varnames.append("LD_LIBRARY_PATH")
+    for varname in varnames:
+        searchpath.extend(os.environ.get(varname, "").split(os.pathsep))
 
     libs = [
         p for p in (os.path.join(n, libname) for n in searchpath) if os.path.exists(p)
     ]
     assert libs, f"Cannot find {libname!r} in {searchpath}"
 
-    nm = run(["nm", "-C", libs[0]], stdout=PIPE, text=True)
-    assert nm.returncode == 0, "nm invocation failed"
+    # Get demangled symbols: Linux nm supports -C, macOS needs c++filt
+    if sys.platform == "darwin":
+        nm = run(["nm", libs[0]], stdout=PIPE, text=True)
+        assert nm.returncode == 0, "nm invocation failed"
+        filt = run(["c++filt"], input=nm.stdout, stdout=PIPE, text=True)
+        assert filt.returncode == 0, "c++filt invocation failed"
+        symbols = filt.stdout
+    else:
+        nm = run(["nm", "-C", libs[0]], stdout=PIPE, text=True)
+        assert nm.returncode == 0, "nm invocation failed"
+        symbols = nm.stdout
 
     signature = re.compile(r"MsgStream& operator<< <char \[\d+\]>")
-    lines = [line for line in nm.stdout.splitlines() if signature.search(line)]
+    lines = [line for line in symbols.splitlines() if signature.search(line)]
 
     assert not lines, "found MsgStream operator<< specialization"
     print("SUCCESS: no MsgStream operator<< specialization found")
