From 454f86a280df86a8045a33f045ff81a243de7009 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Sat, 17 Jan 2026 23:45:48 +0100
Subject: [PATCH 3/9] fix: Normalize strsignal output for macOS compatibility

On macOS, strsignal() appends ": N" (where N is the signal number) to the
description, e.g. "Interrupt: 2" instead of "Interrupt". Strip this suffix
for consistent output across platforms.
---
 GaudiUtils/src/component/SignalMonitorSvc.cpp | 23 ++++++++++++++-----
 1 file changed, 17 insertions(+), 6 deletions(-)

diff --git a/GaudiUtils/src/component/SignalMonitorSvc.cpp b/GaudiUtils/src/component/SignalMonitorSvc.cpp
index de6dae661..4376c4dd4 100644
--- a/GaudiUtils/src/component/SignalMonitorSvc.cpp
+++ b/GaudiUtils/src/component/SignalMonitorSvc.cpp
@@ -1,5 +1,5 @@
 /***********************************************************************************\
-* (c) Copyright 1998-2025 CERN for the benefit of the LHCb and ATLAS collaborations *
+* (c) Copyright 1998-2026 CERN for the benefit of the LHCb and ATLAS collaborations *
 *                                                                                   *
 * This software is distributed under the terms of the Apache version 2 licence,     *
 * copied verbatim in the file "LICENSE".                                            *
@@ -20,6 +20,7 @@
 #include <csignal>
 #include <cstring>
 #include <iostream>
+#include <string>
 
 namespace Gaudi {
   namespace Utils {
@@ -148,9 +149,19 @@ namespace Gaudi {
 #include <GaudiKernel/IIncidentSvc.h>
 
 namespace {
-  const char* sig_desc( int signum ) {
-    if ( signum >= NSIG || signum < 0 ) return nullptr;
-    return strsignal( signum );
+  std::string sig_desc( int signum ) {
+    if ( signum >= NSIG || signum < 0 ) return {};
+    const char* desc = strsignal( signum );
+    if ( !desc ) return {};
+    std::string result( desc );
+    // On macOS, strsignal appends ": N" where N is the signal number
+    // Strip this suffix for consistent output across platforms
+    std::string suffix = ": " + std::to_string( signum );
+    if ( result.size() > suffix.size() &&
+         result.compare( result.size() - suffix.size(), suffix.size(), suffix ) == 0 ) {
+      result.resize( result.size() - suffix.size() );
+    }
+    return result;
   }
 
   /// Helper class to map signal names and numbers.
@@ -267,8 +278,8 @@ namespace {
     inline void i_addSignal( int signum, const char* signame ) {
       m_num2id[signum]    = signame;
       m_name2num[signame] = signum;
-      const char* desc    = sig_desc( signum );
-      if ( desc ) {
+      std::string desc    = sig_desc( signum );
+      if ( !desc.empty() ) {
         m_num2desc[signum] = desc;
         m_name2num[desc]   = signum;
       }
