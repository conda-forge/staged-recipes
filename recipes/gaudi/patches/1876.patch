From 0b1de570b46e734202a36ed604483486101f1c3f Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Fri, 9 Jan 2026 21:48:12 +0100
Subject: [PATCH 1/3] fix: Use configurable Python install path in installation
 tests

The cmake.test_gaudi_install_check test had hardcoded "python/" paths
for checking Python module installation. When GAUDI_INSTALL_PYTHONDIR
is set to a different path (e.g., lib/pythonX.Y/site-packages for
conda packaging), these checks would fail.

Now the test uses the GAUDI_INSTALL_PYTHONDIR variable which is passed
from the main CMake configuration.
---
 cmake/tests/testGaudiInstallation.cmake | 35 +++++++++++++------------
 1 file changed, 18 insertions(+), 17 deletions(-)

diff --git a/cmake/tests/testGaudiInstallation.cmake b/cmake/tests/testGaudiInstallation.cmake
index cf145d2f6b..342370350c 100644
--- a/cmake/tests/testGaudiInstallation.cmake
+++ b/cmake/tests/testGaudiInstallation.cmake
@@ -1,5 +1,5 @@
 #####################################################################################
-# (c) Copyright 2020-2025 CERN for the benefit of the LHCb and ATLAS collaborations #
+# (c) Copyright 2020-2026 CERN for the benefit of the LHCb and ATLAS collaborations #
 #                                                                                   #
 # This software is distributed under the terms of the Apache version 2 licence,     #
 # copied verbatim in the file "LICENSE".                                            #
@@ -131,9 +131,9 @@ elseif(DEFINED TEST_GAUDI_INSTALL_FILES_EXIST) # check some files that should be
         message(FATAL_ERROR "Merged confdb not found,"
             " Gaudi.confdb not found in lib/")
     endif()
-    if(NOT EXISTS ${GAUDI_INSTALL_DIR}/python/GaudiUtils/GaudiUtilsConf.py)
+    if(NOT EXISTS ${GAUDI_INSTALL_PYTHONDIR}/GaudiUtils/GaudiUtilsConf.py)
         message(FATAL_ERROR "genconf python scripts not installed correctly,"
-            " GaudiUtilsConf.py not found in python/GaudiUtils/")
+            " GaudiUtilsConf.py not found in ${GAUDI_INSTALL_PYTHONDIR}/GaudiUtils/")
     endif()
     # GaudiDict.rootmap
     if(NOT EXISTS ${GAUDI_INSTALL_DIR}/lib/GaudiDict.rootmap)
@@ -146,34 +146,34 @@ elseif(DEFINED TEST_GAUDI_INSTALL_FILES_EXIST) # check some files that should be
             " GaudiKernelDict_rdict.pcm not found in lib/")
     endif()
     # Check python modules
-    if(NOT EXISTS ${GAUDI_INSTALL_DIR}/python/GaudiKernel/ConfigurableDb.py)
+    if(NOT EXISTS ${GAUDI_INSTALL_PYTHONDIR}/GaudiKernel/ConfigurableDb.py)
         message(FATAL_ERROR "Python modules not installed correctly,"
-            " ConfigurableDb.py not found in python/GaudiKernel/")
+            " ConfigurableDb.py not found in ${GAUDI_INSTALL_PYTHONDIR}/GaudiKernel/")
     endif()
-    if(NOT EXISTS ${GAUDI_INSTALL_DIR}/python/Gaudi/Main.py)
+    if(NOT EXISTS ${GAUDI_INSTALL_PYTHONDIR}/Gaudi/Main.py)
         message(FATAL_ERROR "Python modules not installed correctly,"
-            " Main.py not found in python/Gaudi/")
+            " Main.py not found in ${GAUDI_INSTALL_PYTHONDIR}/Gaudi/")
     endif()
-    if(NOT EXISTS ${GAUDI_INSTALL_DIR}/python/GaudiHive/precedence.py)
+    if(NOT EXISTS ${GAUDI_INSTALL_PYTHONDIR}/GaudiHive/precedence.py)
         message(FATAL_ERROR "Python modules not installed correctly,"
-            " precedence.py not found in python/GaudiHive/")
+            " precedence.py not found in ${GAUDI_INSTALL_PYTHONDIR}/GaudiHive/")
     endif()
-    if(NOT EXISTS ${GAUDI_INSTALL_DIR}/python/GaudiMP/GMPBase.py)
+    if(NOT EXISTS ${GAUDI_INSTALL_PYTHONDIR}/GaudiMP/GMPBase.py)
         message(FATAL_ERROR "Python modules not installed correctly,"
-            " GMPBase.py not found in python/GaudiMP/")
+            " GMPBase.py not found in ${GAUDI_INSTALL_PYTHONDIR}/GaudiMP/")
     endif()
-    if(NOT EXISTS ${GAUDI_INSTALL_DIR}/python/GaudiSvc/ExtraModules.py)
+    if(NOT EXISTS ${GAUDI_INSTALL_PYTHONDIR}/GaudiSvc/ExtraModules.py)
         message(FATAL_ERROR "Python modules not installed correctly,"
-            " ExtraModules.py not found in python/GaudiSvc/")
+            " ExtraModules.py not found in ${GAUDI_INSTALL_PYTHONDIR}/GaudiSvc/")
     endif()
-    if(NOT EXISTS ${GAUDI_INSTALL_DIR}/python/GaudiTesting/GaudiExeTest.py)
+    if(NOT EXISTS ${GAUDI_INSTALL_PYTHONDIR}/GaudiTesting/GaudiExeTest.py)
         message(FATAL_ERROR "Python modules not installed correctly,"
-            " GaudiExeTest.py not found in python/GaudiTesting/")
+            " GaudiExeTest.py not found in ${GAUDI_INSTALL_PYTHONDIR}/GaudiTesting/")
     endif()
     # -- check binary python modules
-    if(NOT EXISTS ${GAUDI_INSTALL_DIR}/python/GaudiTestSuite/PyExample.so)
+    if(NOT EXISTS ${GAUDI_INSTALL_PYTHONDIR}/GaudiTestSuite/PyExample.so)
         message(FATAL_ERROR "Binary python modules not installed correctly,"
-            " PyExample.so not found in python/GaudiTestSuite/")
+            " PyExample.so not found in ${GAUDI_INSTALL_PYTHONDIR}/GaudiTestSuite/")
     endif()
     # Check config files
     if(NOT EXISTS ${GAUDI_INSTALL_DIR}/lib/cmake/Gaudi/GaudiConfig.cmake)
@@ -226,6 +226,7 @@ else()
     add_test(NAME cmake.test_gaudi_install_check
              COMMAND ${CMAKE_COMMAND} -D TEST_GAUDI_INSTALL_FILES_EXIST:BOOL=TRUE
                                       -D GAUDI_INSTALL_DIR=${tmpInstallDest}
+                                      -D GAUDI_INSTALL_PYTHONDIR=${GAUDI_INSTALL_PYTHONDIR}
                                       -P ${CMAKE_CURRENT_LIST_FILE})
     set_tests_properties(cmake.test_gaudi_install_check PROPERTIES
         DEPENDS cmake.test_gaudi_install
-- 
