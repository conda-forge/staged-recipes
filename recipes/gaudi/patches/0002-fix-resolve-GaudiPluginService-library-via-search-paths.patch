From f682b0234281e6c74853d999ffcef741e15bbc9d Mon Sep 17 00:00:00 2001
From: Chris Burr <chrisburr73@gmail.com>
Date: Sat, 6 Jun 2026 08:14:33 +0200
Subject: [PATCH] fix: resolve GaudiPluginService library via search paths in
 cpluginsvc

On macOS dyld does not honour LD_LIBRARY_PATH and SIP strips DYLD_*
environment variables when executing protected binaries such as /bin/sh
and /usr/bin/env, so loading libGaudiPluginService by bare name fails in
the build tree (e.g. from genconfuser.py via ConfigurableDb). Fall back
to searching GAUDI_PLUGIN_PATH and (DY)LD_LIBRARY_PATH for the library
and load it by absolute path when the bare-name dlopen fails.
---
 .../python/GaudiPluginService/cpluginsvc.py   | 25 ++++++++++++++++++-
 1 file changed, 24 insertions(+), 1 deletion(-)

diff --git a/GaudiPluginService/python/GaudiPluginService/cpluginsvc.py b/GaudiPluginService/python/GaudiPluginService/cpluginsvc.py
index 4de1367..0f451a0 100644
--- a/GaudiPluginService/python/GaudiPluginService/cpluginsvc.py
+++ b/GaudiPluginService/python/GaudiPluginService/cpluginsvc.py
@@ -56,8 +56,31 @@ def _get_filename():
     return fname
 
 
+def _load_lib(fname):
+    try:
+        return ctypes.CDLL(fname, ctypes.RTLD_GLOBAL)
+    except OSError:
+        # On macOS dyld ignores LD_LIBRARY_PATH and SIP strips DYLD_* across
+        # protected executables (e.g. /bin/sh, /usr/bin/env), so a bare name
+        # cannot be resolved in the build tree. Resolve the library via
+        # Gaudi's search paths and retry with an absolute path.
+        import os
+
+        for pathvar in (
+            "GAUDI_PLUGIN_PATH",
+            "LD_LIBRARY_PATH",
+            "DYLD_LIBRARY_PATH",
+            "DYLD_FALLBACK_LIBRARY_PATH",
+        ):
+            for d in os.environ.get(pathvar, "").split(os.pathsep):
+                full = os.path.join(d, fname)
+                if d and os.path.exists(full):
+                    return ctypes.CDLL(full, ctypes.RTLD_GLOBAL)
+        raise
+
+
 _libname = _get_filename()
-_lib = ctypes.CDLL(_libname, ctypes.RTLD_GLOBAL)
+_lib = _load_lib(_libname)
 
 
 class Registry(ctypes.Structure):
