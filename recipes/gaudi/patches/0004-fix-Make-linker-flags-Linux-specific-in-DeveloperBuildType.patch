From 0057d1454eef5d84cec8d8219b1ffaeb25ee060b Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Sun, 18 Jan 2026 14:00:59 +0100
Subject: [PATCH 1/9] fix: Make linker flags Linux-specific in
 DeveloperBuildType

The -Wl,--no-undefined and -Wl,-z,max-page-size flags are GNU ld
specific and not supported by the macOS linker.
---
 cmake/DeveloperBuildType.cmake | 14 ++++++++------
 1 file changed, 8 insertions(+), 6 deletions(-)

diff --git a/cmake/DeveloperBuildType.cmake b/cmake/DeveloperBuildType.cmake
index 6d297a8c9..6e1ccbe9b 100644
--- a/cmake/DeveloperBuildType.cmake
+++ b/cmake/DeveloperBuildType.cmake
@@ -1,5 +1,5 @@
 #####################################################################################
-# (c) Copyright 2020 CERN for the benefit of the LHCb and ATLAS collaborations      #
+# (c) Copyright 2020-2026 CERN for the benefit of the LHCb and ATLAS collaborations #
 #                                                                                   #
 # This software is distributed under the terms of the Apache version 2 licence,     #
 # copied verbatim in the file "LICENSE".                                            #
@@ -34,11 +34,13 @@ endif()
 set(CMAKE_CXX_FLAGS_${_CONFIG} "${_flags}"
     CACHE INTERNAL "Compile flags for ${_config} build type")
 
-# Set linker flags
-foreach(bin_type IN ITEMS EXE STATIC SHARED MODULE)
-    set(CMAKE_${bin_type}_LINKER_FLAGS_${_CONFIG} "-Wl,--no-undefined -Wl,-z,max-page-size=0x1000"
-        CACHE INTERNAL "Linker flags for ${bin_type} with ${_config} build type")
-endforeach()
+# Set linker flags (Linux-specific)
+if(CMAKE_SYSTEM_NAME STREQUAL "Linux")
+    foreach(bin_type IN ITEMS EXE STATIC SHARED MODULE)
+        set(CMAKE_${bin_type}_LINKER_FLAGS_${_CONFIG} "-Wl,--no-undefined -Wl,-z,max-page-size=0x1000"
+            CACHE INTERNAL "Linker flags for ${bin_type} with ${_config} build type")
+    endforeach()
+endif()
 
 # Add the build types to the possible ones
 if(CMAKE_CONFIGURATION_TYPES)
-- 
