+"""Helpers to locate and load Gaudi shared libraries by name.
+
+Loading a library by its bare filename relies on the dynamic loader's search
+path (``LD_LIBRARY_PATH``/RPATH on Linux). On macOS ``dlopen`` does not fall
+back to those paths for a bare name, and SIP strips ``DYLD_*`` across protected
+executables (e.g. ``/bin/sh``, ``/usr/bin/env``), so the bare name often cannot
+be resolved. These helpers resolve the library to an absolute path first.
+
+This module deliberately has no import-time side effects (in particular it does
+not load any shared library), so it is cheap and safe to import from anywhere.
+"""
+
+import ctypes
+import ctypes.util
+import os
+import platform
+import sys
+
+_SUFFIXES = {"Darwin": ".dylib", "Windows": ".dll", "Linux": ".so"}
+
+
+def lib_filename(stem):
+    """Return the platform-appropriate shared library filename for ``stem``.
+
+    e.g. ``lib_filename("GaudiKernel")`` -> ``libGaudiKernel.dylib`` on macOS,
+    ``libGaudiKernel.so`` on Linux.
+    """
+    return "lib{}{}".format(stem, _SUFFIXES.get(platform.system(), ".so"))
+
+
+def _candidate_dirs():
+    """Directories that may contain Gaudi shared libraries, most specific first."""
+    dirs = []
+    # Explicit runtime search paths. On macOS dlopen ignores these for bare
+    # names, but when present they point at the build/runtime library dirs.
+    for var in (
+        "LD_LIBRARY_PATH",
+        "DYLD_LIBRARY_PATH",
+        "DYLD_FALLBACK_LIBRARY_PATH",
+        "GAUDI_PLUGIN_PATH",
+    ):
+        dirs += os.environ.get(var, "").split(os.pathsep)
+    # Relative to this package: libraries live in a sibling lib/lib64 both in the
+    # build tree (<prefix>/python/GaudiPluginService) and the install tree
+    # (<prefix>/lib/pythonX.Y/site-packages/GaudiPluginService).
+    prefix = os.path.dirname(os.path.abspath(__file__))
+    for _ in range(6):
+        prefix = os.path.dirname(prefix)
+        if not prefix or prefix == os.path.dirname(prefix):
+            break
+        dirs += [os.path.join(prefix, "lib"), os.path.join(prefix, "lib64")]
+    # The interpreter's prefixes (covers conda-style layouts).
+    for p in (sys.prefix, sys.exec_prefix):
+        dirs += [os.path.join(p, "lib"), os.path.join(p, "lib64")]
+    return dirs
+
+
+def resolve_lib(name):
+    """Resolve shared library ``name`` to an absolute path when possible.
+
+    Searches the directories where the library may live and returns an absolute
+    path to the first match. Returns ``name`` unchanged if nothing is found,
+    letting the dynamic loader make a final attempt (e.g. via RPATH).
+    """
+    if os.path.isabs(name):
+        return name
+    seen = set()
+    for d in _candidate_dirs():
+        if not d or d in seen:
+            continue
+        seen.add(d)
+        candidate = os.path.join(d, name)
+        if os.path.exists(candidate):
+            return candidate
+    # Last resort: let ctypes try to resolve the bare stem (strip lib/.ext).
+    stem = name[3:] if name.startswith("lib") else name
+    stem = stem.split(".", 1)[0]
+    return ctypes.util.find_library(stem) or name
+
+
+def load_lib(name, pydll=False):
+    """``dlopen`` ``name`` with ``RTLD_GLOBAL``, resolving an absolute path first.
+
+    Set ``pydll=True`` to use ``PyDLL`` (required when the library calls into the
+    Python C API without releasing the GIL).
+    """
+    loader = ctypes.PyDLL if pydll else ctypes.CDLL
+    return loader(resolve_lib(name), mode=ctypes.RTLD_GLOBAL)
