From 6283d4b095e962ab9c0efa279f526be35b495b75 Mon Sep 17 00:00:00 2001
From: Chris Burr <chrisburr73@gmail.com>
Date: Wed, 10 Jun 2026 22:14:40 +0200
Subject: [PATCH 2/2] fix: use platform-appropriate library path in confdb test
 on macOS

loadConfigurableDb() searches DYLD_LIBRARY_PATH on macOS (and LD_LIBRARY_PATH
elsewhere), but the test helper fixLibPath only set LD_LIBRARY_PATH, so on
macOS the fixture directories were never searched and the test picked up the
real confdb files instead. Set the same variable loadConfigurableDb reads.
---
 GaudiKernel/tests/pytest/confdb/test_confdb.py | 17 ++++++++++-------
 1 file changed, 10 insertions(+), 7 deletions(-)

diff --git a/GaudiKernel/tests/pytest/confdb/test_confdb.py b/GaudiKernel/tests/pytest/confdb/test_confdb.py
index e44344b..7c4a735 100644
--- a/GaudiKernel/tests/pytest/confdb/test_confdb.py
+++ b/GaudiKernel/tests/pytest/confdb/test_confdb.py
@@ -19,24 +19,27 @@ from common import MockLoggingHandler, data_root
 
 class fixLibPath(object):
     """
-    Temporarily override the LD_LIBRARY_PATH.
+    Temporarily override the library search path used by loadConfigurableDb to
+    locate .confdb files (DYLD_LIBRARY_PATH on macOS, LD_LIBRARY_PATH elsewhere).
     """
 
+    _var = "DYLD_LIBRARY_PATH" if sys.platform == "darwin" else "LD_LIBRARY_PATH"
+
     def __init__(self, entries):
         env = os.environ
-        self.old_lib_path = env.get("LD_LIBRARY_PATH")
-        new_path = entries + env.get("LD_LIBRARY_PATH", "").split(os.pathsep)
-        env["LD_LIBRARY_PATH"] = os.pathsep.join(new_path)
+        self.old_lib_path = env.get(self._var)
+        new_path = entries + env.get(self._var, "").split(os.pathsep)
+        env[self._var] = os.pathsep.join(new_path)
 
     def __enter__(self):
         return self
 
     def __exit__(self, exc_type, exc_value, traceback):
         if self.old_lib_path is None:
-            if "LD_LIBRARY_PATH" in os.environ:
-                del os.environ["LD_LIBRARY_PATH"]
+            if self._var in os.environ:
+                del os.environ[self._var]
         else:
-            os.environ["LD_LIBRARY_PATH"] = self.old_lib_path
+            os.environ[self._var] = self.old_lib_path
 
 
 def setup():
