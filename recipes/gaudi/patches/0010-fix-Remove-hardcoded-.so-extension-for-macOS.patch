From bb43099893cf12b799e0c236d8b0062ef54651d6 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Sat, 17 Jan 2026 17:32:44 +0100
Subject: [PATCH 7/9] fix: Remove hardcoded .so extension for macOS
 compatibility

Let ROOT resolve the platform-appropriate library extension
automatically (.dylib on macOS, .so on Linux).
---
 GaudiTestSuite/options/CustomAppFromOptions.py | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/GaudiTestSuite/options/CustomAppFromOptions.py b/GaudiTestSuite/options/CustomAppFromOptions.py
index ea842684f..e59c988d5 100644
--- a/GaudiTestSuite/options/CustomAppFromOptions.py
+++ b/GaudiTestSuite/options/CustomAppFromOptions.py
@@ -1,5 +1,5 @@
 #####################################################################################
-# (c) Copyright 1998-2019 CERN for the benefit of the LHCb and ATLAS collaborations #
+# (c) Copyright 1998-2026 CERN for the benefit of the LHCb and ATLAS collaborations #
 #                                                                                   #
 # This software is distributed under the terms of the Apache version 2 licence,     #
 # copied verbatim in the file "LICENSE".                                            #
@@ -20,7 +20,7 @@ with warnings.catch_warnings():
     import cppyy
 
 # - we have to load GaudiKernel get the base class
-cppyy.gbl.gSystem.Load("libGaudiKernel.so")
+cppyy.gbl.gSystem.Load("libGaudiKernel")
 
 # - pass to ROOT interpreter our code
 cppyy.gbl.gInterpreter.Declare(
