@@ -286,7 +286,7 @@ namespace concurrency {
 
       for ( auto& pr : m_scc ) {
         if ( pr.second.size() > 1 ) {
-          m_status << "\n o [lowlink:" << std::to_string( pr.first ) << "] |";
+          m_status << "\n o |";
 
           // rotate SCCs to get reproducible order
           std::vector sortedSCC( pr.second.begin(), pr.second.end() );
