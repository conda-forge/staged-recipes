From b7a598cacfede69b215747556bae8e76a13ce6b5 Mon Sep 17 00:00:00 2001
From: Giordon Stark <kratsg@gmail.com>
Date: Fri, 1 May 2026 10:36:15 -0400
Subject: [PATCH 03/10] patch externals

---
 .../Fastor/expressions/expression_traits.h    |  2 +-
 external/include/Fastor/tensor/TensorTraits.h | 19 +++++++++++++------
 2 files changed, 14 insertions(+), 7 deletions(-)

diff --git a/external/include/Fastor/expressions/expression_traits.h b/external/include/Fastor/expressions/expression_traits.h
index 0c7ae3c..499ba01 100644
--- a/external/include/Fastor/expressions/expression_traits.h
+++ b/external/include/Fastor/expressions/expression_traits.h
@@ -318,7 +318,7 @@ using binary_op_simd_vector_t = typename binary_op_simd_vector_type<Derived>::ty
 
 
 
-template<class T>
+template<class T, class>
 struct scalar_type_finder;
 
 } // end of namespace Fastor
diff --git a/external/include/Fastor/tensor/TensorTraits.h b/external/include/Fastor/tensor/TensorTraits.h
index e98aaa8..fafb7fc 100644
--- a/external/include/Fastor/tensor/TensorTraits.h
+++ b/external/include/Fastor/tensor/TensorTraits.h
@@ -22,7 +22,7 @@ namespace Fastor {
 
 /* Find the underlying scalar type of an expression */
 //--------------------------------------------------------------------------------------------------------------------//
-template<class T>
+template<class T, class = void>
 struct scalar_type_finder {
     using type = T;
 };
@@ -32,10 +32,11 @@ struct scalar_type_finder<Tensor<T,Rest...>> {
     using type = T;
 };
 // This specific specialisation is needed to avoid ambiguity for vectors
-template<typename T, size_t N>
-struct scalar_type_finder<Tensor<T,N>> {
-    using type = T;
-};
+// DISABLED: redundant with the variadic Tensor<T,Rest...> above; causes ambiguity with modern clang
+// template<typename T, size_t N>
+// struct scalar_type_finder<Tensor<T,N>> {
+//     using type = T;
+// };
 template<typename T, size_t ... Rest>
 struct scalar_type_finder<TensorMap<T,Rest...>> {
     using type = T;
@@ -46,8 +47,14 @@ struct scalar_type_finder<TensorMap<T,N>> {
     using type = T;
 };
 
+// SFINAE-guarded: exclude Tensor and TensorMap (which have their own specializations above)
+// so that template<class,size_t> does not ambiguously match their two-argument instantiations.
 template<template <class,size_t> class UnaryExpr, typename Expr, size_t DIMS>
-struct scalar_type_finder<UnaryExpr<Expr,DIMS>> {
+struct scalar_type_finder<UnaryExpr<Expr,DIMS>,
+    typename std::enable_if<
+        !std::is_same<UnaryExpr<Expr,DIMS>, Tensor<Expr,DIMS>>::value &&
+        !std::is_same<UnaryExpr<Expr,DIMS>, TensorMap<Expr,DIMS>>::value
+    >::type> {
     using type = typename scalar_type_finder<Expr>::type;
 };
 template<template <class,class,size_t> class Expr, typename TLhs, typename TRhs, size_t DIMS>
-- 
2.45.2

