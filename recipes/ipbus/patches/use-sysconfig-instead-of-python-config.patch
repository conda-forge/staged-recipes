--- a/uhal/python/Makefile
+++ b/uhal/python/Makefile
@@ -62,13 +62,15 @@
 		util
 
 
-CXXFLAGS += -ftemplate-depth-128 -O0 -rdynamic -finline-functions -Wno-inline -DNDEBUG $(shell ${PYTHON}-config --includes)
-LDFLAGS += $(shell ${PYTHON}-config --libs)
+PYTHON_INCLUDES = $(shell ${PYTHON} -c "import sysconfig; i=sysconfig.get_path('include'); p=sysconfig.get_path('platinclude'); print(('-I'+i+' -I'+p) if p and p!=i else ('-I'+i))")
+PYTHON_LIBS = $(shell ${PYTHON} -c "import sysconfig; L=sysconfig.get_config_var; d=L('LIBDIR') or ''; m=L('LDLIBRARY') or L('LIBRARY') or ''; n=(m[3:].split('.')[0] if len(m)>3 else '') if m else ''; s=([('-L'+d)] if d else [])+([('-l'+n)] if n else [])+[(L('LIBS') or ''),(L('SYSLIBS') or '')]; print(' '.join(x for x in s if x))")
+CXXFLAGS += -ftemplate-depth-128 -O0 -rdynamic -finline-functions -Wno-inline -DNDEBUG $(PYTHON_INCLUDES)
+LDFLAGS += $(PYTHON_LIBS)
 
 ifeq (${CACTUS_OS},osx)
   CXXFLAGS += -Wno-c++11-extensions
-  CXXFLAGS += $(shell python-config --cflags)
-  LDFLAGS += $(shell python-config --ldflags)
+  CXXFLAGS += $(PYTHON_INCLUDES)
+  LDFLAGS += $(PYTHON_LIBS)
 else
   LDFLAGS += -Wl,-h -Wl,-Bstatic -Wl,-Bdynamic
 endif
